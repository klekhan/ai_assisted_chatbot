# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to GitHub.

# --- Qdrant Cloud (https://cloud.qdrant.io — free tier) ---
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=documents

# --- Groq (https://console.groq.com — free tier) ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Public key: used by the public chat widget. Baked into the frontend
# build, so treat it as a light abuse-deterrent, NOT a real secret. ---
API_KEY=pick-a-long-random-string-here

# --- Admin key: used only by the /admin dashboard. NEVER put this in the
# frontend's .env / build — the admin types it in at login instead. Make
# this a genuinely strong, different value from API_KEY. ---
ADMIN_KEY=pick-a-different-much-longer-random-string-here

# --- CORS: comma-separated list of frontend URLs allowed to call this API ---
CORS_ORIGINS=http://localhost:5173

# --- Suggested topics shown on the public empty-state chat screen ---
KB_TOPICS=Admissions,Fees,Placements,Hostel,Courses

# --- Supabase (https://supabase.com — free tier) ---
# Stores flagged/unanswered questions, user feedback, and chunk-boost data.
# Get this from: Supabase dashboard -> your project -> Project Settings ->
# Database -> Connection string -> "Connection pooling" tab (NOT "Direct
# connection" — the pooler is built for exactly this kind of app: many
# short-lived connections from a hosted backend, and the free tier's direct
# connection limit is easy to exhaust otherwise). Copy the URI and swap in
# your actual database password.
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# --- Hybrid search (dense + BM25 keyword search, fused with RRF) ---
# Leave as-is unless you have a reason to disable it.
ENABLE_HYBRID_SEARCH=true
RETRIEVAL_FETCH_K=20

# --- Confidence threshold for auto-flagging a question as "unanswered" ---
# Top retrieval score below this triggers logging + (if SMTP is set up) an
# admin email. Tune this against real traffic in /admin — start conservative.
LOW_CONFIDENCE_SCORE=0.35
NOTIFY_ADMIN_ON_LOW_CONFIDENCE=true
NOTIFY_COOLDOWN_MINUTES=60

# --- Verified-answer cache (built automatically from 👍 feedback) ---
VERIFIED_QA_SCORE_THRESHOLD=0.92

# --- Feedback-driven chunk re-ranking (retrieval "learns" from usage) ---
CHUNK_BOOST_WEIGHT=0.01
CHUNK_BOOST_CAP=10

# --- SMTP: sends the "please update the docs" admin email. Leave blank to
# just log unanswered questions to /admin without emailing anyone. ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
ADMIN_NOTIFY_EMAIL=admin@yourinstitution.edu
