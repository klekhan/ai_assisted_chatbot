# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to GitHub.

# --- Qdrant Cloud (https://cloud.qdrant.io — free tier) ---
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=documents

# --- Groq (https://console.groq.com — free tier) ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Your own API key, used to protect your endpoints ---
# Pick any random string. The frontend will send this in a header.
API_KEY=pick-a-long-random-string-here

# --- CORS: comma-separated list of frontend URLs allowed to call this API ---
CORS_ORIGINS=http://localhost:5173
