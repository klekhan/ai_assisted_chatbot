# Copy to ".env" for local dev. NEVER commit the real ".env".

# URL where your FastAPI backend is running
VITE_API_URL=http://127.0.0.1:8000

# Public key used by the chat widget. Must match API_KEY in your backend's
# .env. This gets baked into the built JavaScript, so it is NOT a real
# secret — it only deters casual abuse of your free-tier API quota.
VITE_API_KEY=pick-a-long-random-string-here

# There is deliberately NO admin key variable here. The admin key is typed
# in manually at /admin each session and stored only in the browser's
# localStorage — never in the build — so it can't be extracted from your
# public JavaScript bundle.
